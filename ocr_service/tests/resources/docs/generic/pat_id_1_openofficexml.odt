    <table:table-row>
      <table:table-cell office:value-type="string">
        <text:p>Paracetamol</text:p>
      </table:table-cell>

      <table:table-cell office:value-type="string">
        <text:p>100mg</text:p>
      </table:table-cell>

      <table:table-cell office:value-type="string">
        <text:p>PRN</text:p>
      </table:table-cell>
    </table:table-row>

    <table:table-row>
      <table:table-cell office:value-type="string">
