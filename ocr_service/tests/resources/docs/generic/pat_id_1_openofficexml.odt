      </table:table-cell>

      <table:table-cell office:value-type="string">
        <text:p>20mg</text:p>
      </table:table-cell>

      <table:table-cell office:value-type="string">
        <text:p>OD</text:p>
      </table:table-cell>
    </table:table-row>

   </table:table>

   <text:h text:outline-level="2">
    Risk Assessment
   </text:h>

   <text:list>
    <text:list-item>
      <text:p>Risk to self: Low</text:p>
    </text:list-item>

    <text:list-item>
      <text:p>Risk to others: Low</text:p>
    </text:list-item>

    <text:list-item>
      <text:p>Safeguarding concerns: None identified</text:p>
    </text:list-item>
   </text:list>

   <text:h text:outline-level="2">
    Plan
   </text:h>

   <text:p>
    Continue current medication regime.
   </text:p>

   <text:p>
    Arrange routine blood monitoring for clozapine.
   </text:p>

   <text:p>
    Follow-up appointment in 4 weeks.
   </text:p>

   <text:note text:id="ftn1" text:note-class="footnote">
    <text:note-body>
      <text:p>
        This is a synthetic note for XML parsing tests.
      </text:p>
    </text:note-body>
   </text:note>

